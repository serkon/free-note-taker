{
  "name": "free-note-taker",
  "version": "1.0.0",
  "description": "A complete Notion clone - fully free and open source",
  "private": true,
  "scripts": {
    "services:up": "docker-compose -f backend/docker-compose.yml up -d",
    "services:stop": "docker-compose -f backend/docker-compose.yml stop",
    "services:down": "docker-compose -f backend/docker-compose.yml down",
    "api:dev": "npm --prefix backend run start:dev",
    "web:dev": "npm --prefix frontend run dev",
    "dev": "concurrently --kill-others --names \"API,WEB\" -c \"blue,green\" \"npm run api:dev\" \"npm run web:dev\"",
    "dev:full": "npm run services:up && npm run dev",
    "build": "npm --prefix backend run build && npm --prefix frontend run build",
    "db:push": "npm --prefix backend run db:push",
    "db:seed": "npm --prefix backend run db:seed",
    "db:reset": "npm --prefix backend run db:reset",
    "db:studio": "npm --prefix backend run db:studio"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
